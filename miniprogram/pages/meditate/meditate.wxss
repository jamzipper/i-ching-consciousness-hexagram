.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 100rpx;
}

.timer-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  margin: 36rpx 0;
}

.timer-ring-container {
  position: relative;
  width: 220rpx;
  height: 220rpx;
}

.timer-canvas {
  width: 220rpx;
  height: 220rpx;
}

.timer-num {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: var(--gold);
}

.timer-msg {
  font-size: 26rpx;
  letter-spacing: 0.1em;
}

.btn-wrap {
  text-align: center;
}
