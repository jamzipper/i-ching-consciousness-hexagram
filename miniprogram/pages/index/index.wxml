<view class="container">

  <!-- ══ HEADER ══ -->
  <view class="header">
    <text class="title-main">意　識　卦</text>
    <text class="title-sub">CONSCIOUSNESS HEXAGRAM · I CHING DIVINATION</text>
    <view class="hr"></view>
  </view>

  <!-- ══ STEP 1: Question ══ -->
  <view wx:if="{{currentStep === 1}}" class="card">
    <text class="step-tag">STEP 1 · 問卦</text>
    <text class="card-heading">寫下你的問題</text>
    <textarea
      class="q-input"
      value="{{question}}"
      bindinput="onQuestionInput"
      placeholder="建議使用是非題，例：這次求職有沒有機會？"
      placeholder-class="q-placeholder"
      maxlength="200"
      auto-height
    ></textarea>
    <button class="btn btn-primary" bindtap="goMeditate">開始靜心 →</button>
    <text class="hint-text">以出離心專注問題 10–15 秒，不執著得失。</text>
  </view>

  <!-- ══ STEP 2: Meditation Timer ══ -->
  <view wx:if="{{currentStep === 2}}" class="card">
    <text class="step-tag">STEP 2 · 靜心</text>
    <text class="card-heading">觀想正體漢字</text>
    <text class="hint-text">閉眼專注於問題。讓一個正體漢字自然浮現。</text>

    <view class="timer-wrap">
      <canvas type="2d" id="timerCanvas" class="timer-canvas"></canvas>
      <view class="timer-inner">
        <text class="timer-num">{{countdown}}</text>
      </view>
    </view>
    <text class="timer-msg {{timerDone ? 'timer-done' : ''}}">{{timerMsg}}</text>

    <button wx:if="{{skipVisible}}" class="btn btn-skip" bindtap="skipTimer">跳過 →</button>
  </view>

  <!-- ══ STEP 3: Character Input ══ -->
  <view wx:if="{{currentStep === 3}}" class="card">
    <text class="step-tag">STEP 3 · 輸入字</text>
    <text class="card-heading">輸入觀想的漢字</text>

    <!-- Branch info -->
    <view class="branch-box">
      <text class="branch-char">{{branchChar}}</text>
      <view class="branch-detail">
        <text>時辰：{{branchName}}時（{{branchRange}}）</text>
        <text>時辰數：{{branchNum}}</text>
        <text>現在時間：{{currentTime}}</text>
      </view>
    </view>

    <!-- Character field -->
    <view class="field-group">
      <text class="field-label">觀想的字（正體）</text>
      <input
        class="char-input"
        value="{{charInput}}"
        bindinput="onCharInput"
        placeholder="輸入漢字"
        placeholder-class="input-ph"
        maxlength="4"
        focus="{{charFocus}}"
      />
    </view>

    <!-- Conversion display -->
    <view wx:if="{{convState === 'converted'}}" class="conv-row">
      <text class="conv-orig">{{origChar}}</text>
      <text class="conv-arrow"> → </text>
      <text class="tc-char">{{tcChar}}</text>
      <text class="conv-badge">繁體轉換</text>
    </view>
    <view wx:elif="{{convState === 'already'}}" class="conv-row">
      <text class="tc-char">{{tcChar}}</text>
      <text class="conv-badge is-tc">已是繁體</text>
    </view>

    <!-- Stroke count -->
    <view class="field-group">
      <text class="field-label">筆畫數</text>
      <view class="stroke-row">
        <input
          class="stroke-input"
          value="{{strokeInput}}"
          bindinput="onStrokeInput"
          placeholder="自動填入或手動輸入"
          placeholder-class="input-ph"
          type="number"
        />
        <text wx:if="{{strokeLoading}}" class="stroke-hint">查詢中…</text>
        <text wx:elif="{{strokeAuto}}" class="stroke-hint auto-note">已自動填入</text>
        <text wx:elif="{{strokeFailed}}" class="stroke-hint fail-note">請手動輸入</text>
      </view>
    </view>

    <button class="btn btn-primary" bindtap="doCalculate">起卦 →</button>
  </view>

  <!-- ══ STEP 4: Result ══ -->
  <view wx:if="{{currentStep === 4}}" class="card">
    <text class="step-tag">RESULT · 卦象</text>
    <text class="r-question">{{rQuestion}}</text>

    <!-- Calc summary table -->
    <view class="calc-table">
      <view class="calc-row">
        <text class="calc-label">字的筆畫</text>
        <text class="calc-val">{{rawStrokes}} 畫</text>
      </view>
      <view class="calc-row">
        <text class="calc-label">時辰</text>
        <text class="calc-val">{{branchLabel}}</text>
      </view>
    </view>

    <view class="hr" style="margin: 18rpx 0;"></view>

    <!-- Hexagram pair -->
    <view class="hex-row">
      <!-- 本卦 -->
      <view class="hex-block">
        <text class="hex-label-top">本 卦 · 當前處境</text>
        <view class="hex-lines">
          <view
            wx:for="{{origLines}}"
            wx:key="num"
            class="hex-line {{item.moving ? 'moving' : ''}}"
          >
            <text class="hex-line-num">{{item.num}}</text>
            <view wx:if="{{item.yang}}" class="yang {{item.moving ? 'yang-moving' : ''}}"></view>
            <view wx:else class="yin-wrap">
              <view class="yin-l {{item.moving ? 'yin-moving' : ''}}"></view>
              <view class="yin-r {{item.moving ? 'yin-moving' : ''}}"></view>
            </view>
          </view>
        </view>
        <text class="hex-kw">{{origKw}}</text>
        <text class="hex-name">{{origName}}</text>
      </view>

      <text class="arrow-between">→</text>

      <!-- 之卦 -->
      <view class="hex-block">
        <text class="hex-label-top">之 卦 · 發展趨勢</text>
        <view class="hex-lines">
          <view
            wx:for="{{futLines}}"
            wx:key="num"
            class="hex-line"
          >
            <text class="hex-line-num">{{item.num}}</text>
            <view wx:if="{{item.yang}}" class="yang"></view>
            <view wx:else class="yin-wrap">
              <view class="yin-l"></view>
              <view class="yin-r"></view>
            </view>
          </view>
        </view>
        <text class="hex-kw">{{futKw}}</text>
        <text class="hex-name">{{futName}}</text>
      </view>
    </view>

    <text class="result-note">本卦象徵當下，之卦象徵趨勢。</text>

    <!-- Interpretation toggle -->
    <button class="interp-toggle" bindtap="toggleInterp">
      卦象解析 {{interpOpen ? '▴' : '▾'}}
    </button>
    <view wx:if="{{interpOpen}}" class="interp-section">
      <view class="interp-card">
        <text class="interp-tag">本卦 · 當前處境</text>
        <text class="interp-name">{{origName}}</text>
        <text class="interp-body">{{origInterp}}</text>
      </view>
      <view class="interp-card">
        <text class="interp-tag">之卦 · 發展趨勢</text>
        <text class="interp-name">{{futName}}</text>
        <text class="interp-body">{{futInterp}}</text>
      </view>
    </view>

    <view style="text-align:center; margin-top: 44rpx;">
      <button class="btn" bindtap="doReset">重新起卦</button>
    </view>
  </view>

  <!-- Footer -->
  <view class="footer">
    <text>意識卦 · 易經白話講座</text>
  </view>

</view>
