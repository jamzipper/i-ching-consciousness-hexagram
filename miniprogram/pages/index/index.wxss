/* ── Layout ── */
.container {
  min-height: 100vh;
  background: #080806;
  padding: 0 32rpx 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── Header ── */
.header {
  text-align: center;
  padding: 80rpx 32rpx 48rpx;
  width: 100%;
}
.title-main {
  display: block;
  font-size: 72rpx;
  color: #c9a84c;
  letter-spacing: 0.5em;
  text-shadow: 0 0 40rpx rgba(201,168,76,0.45);
  font-family: 'Songti SC', 'STSong', serif;
}
.title-sub {
  display: block;
  font-size: 22rpx;
  color: #7a6330;
  letter-spacing: 0.25em;
  margin-top: 16rpx;
  text-transform: uppercase;
}
.hr {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #7a6330, transparent);
  margin: 32rpx auto 0;
  width: 80%;
}

/* ── Card ── */
.card {
  background: #111108;
  border: 1rpx solid #2a2010;
  border-radius: 6rpx;
  padding: 52rpx 44rpx;
  width: 100%;
  max-width: 680rpx;
  margin-bottom: 32rpx;
}
.step-tag {
  display: block;
  font-size: 22rpx;
  color: #7a6330;
  letter-spacing: 0.3em;
  margin-bottom: 16rpx;
}
.card-heading {
  display: block;
  font-size: 42rpx;
  color: #c9a84c;
  margin-bottom: 32rpx;
  letter-spacing: 0.05em;
}

/* ── Step 1 ── */
.q-input {
  width: 100%;
  min-height: 140rpx;
  background: #080806;
  border: 1rpx solid #2a2010;
  border-radius: 4rpx;
  padding: 24rpx;
  color: #e8d5a3;
  font-size: 30rpx;
  line-height: 1.8;
  margin-bottom: 32rpx;
}
.q-placeholder { color: #7a6330; }

.hint-text {
  display: block;
  font-size: 24rpx;
  color: #7a6330;
  line-height: 1.7;
  margin-top: 20rpx;
}

/* ── Buttons ── */
.btn {
  display: block;
  width: 100%;
  padding: 28rpx 0;
  background: transparent;
  border: 1rpx solid #7a6330;
  border-radius: 4rpx;
  color: #c9a84c;
  font-size: 30rpx;
  letter-spacing: 0.2em;
  text-align: center;
  margin-top: 24rpx;
}
.btn::after { border: none; }
.btn-primary {
  border-color: #c9a84c;
  color: #c9a84c;
}
.btn-skip {
  margin-top: 40rpx;
  border-color: #7a6330;
  color: #7a6330;
  font-size: 26rpx;
}

/* ── Timer (Step 2) ── */
.timer-wrap {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  margin: 40rpx auto 24rpx;
}
.timer-canvas {
  width: 240rpx;
  height: 240rpx;
}
.timer-inner {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.timer-num {
  font-size: 72rpx;
  color: #c9a84c;
  font-family: 'Songti SC', serif;
}
.timer-msg {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #7a6330;
  margin-top: 8rpx;
}
.timer-done { color: #c9a84c; }

/* ── Step 3 ── */
.branch-box {
  display: flex;
  align-items: center;
  gap: 28rpx;
  background: #080806;
  border: 1rpx solid #2a2010;
  border-radius: 4rpx;
  padding: 28rpx;
  margin-bottom: 36rpx;
}
.branch-char {
  font-size: 72rpx;
  color: #c9a84c;
  line-height: 1;
  min-width: 80rpx;
  text-align: center;
}
.branch-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.branch-detail text {
  font-size: 24rpx;
  color: #7a6330;
  line-height: 1.6;
}

.field-group {
  margin-bottom: 32rpx;
}
.field-label {
  display: block;
  font-size: 24rpx;
  color: #7a6330;
  margin-bottom: 14rpx;
  letter-spacing: 0.1em;
}
.char-input {
  width: 100%;
  background: #080806;
  border: 1rpx solid #2a2010;
  border-radius: 4rpx;
  padding: 24rpx;
  color: #e8d5a3;
  font-size: 36rpx;
  text-align: center;
  letter-spacing: 0.3em;
}
.input-ph { color: #7a6330; font-size: 26rpx; }

.conv-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}
.conv-orig {
  font-size: 40rpx;
  color: #7a6330;
}
.conv-arrow {
  font-size: 28rpx;
  color: #7a6330;
}
.tc-char {
  font-size: 48rpx;
  color: #c9a84c;
}
.conv-badge {
  font-size: 22rpx;
  color: #c9a84c;
  border: 1rpx solid #c9a84c;
  border-radius: 40rpx;
  padding: 4rpx 18rpx;
}
.is-tc { color: #7a6330; border-color: #7a6330; }

.stroke-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.stroke-input {
  flex: 1;
  background: #080806;
  border: 1rpx solid #2a2010;
  border-radius: 4rpx;
  padding: 24rpx;
  color: #e8d5a3;
  font-size: 32rpx;
  text-align: center;
}
.stroke-hint {
  font-size: 24rpx;
  color: #7a6330;
}
.auto-note { color: #c9a84c; }
.fail-note { color: #c0392b; }

/* ── Step 4: Result ── */
.r-question {
  display: block;
  font-size: 28rpx;
  color: #7a6330;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.calc-table {
  width: 100%;
  margin-bottom: 8rpx;
}
.calc-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #2a2010;
}
.calc-label {
  font-size: 26rpx;
  color: #7a6330;
}
.calc-val {
  font-size: 26rpx;
  color: #e8d5a3;
}

/* ── Hex display ── */
.hex-row {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
  margin: 24rpx 0;
  gap: 8rpx;
}
.hex-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.hex-label-top {
  font-size: 22rpx;
  color: #7a6330;
  letter-spacing: 0.1em;
  margin-bottom: 20rpx;
  text-align: center;
}
.hex-lines {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}
.hex-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  height: 24rpx;
}
.hex-line-num {
  font-size: 20rpx;
  color: #7a6330;
  width: 28rpx;
  text-align: right;
}
.yang {
  width: 120rpx;
  height: 12rpx;
  background: #c9a84c;
  border-radius: 2rpx;
}
.yin-wrap {
  display: flex;
  gap: 10rpx;
}
.yin-l, .yin-r {
  width: 52rpx;
  height: 12rpx;
  background: #c9a84c;
  border-radius: 2rpx;
}
/* Moving line — red */
.hex-line.moving .hex-line-num { color: #c0392b; }
.yang-moving {
  background: #c0392b;
  box-shadow: 0 0 8rpx rgba(192,57,43,0.7);
}
.yin-moving {
  background: #c0392b;
  box-shadow: 0 0 8rpx rgba(192,57,43,0.7);
}

.hex-kw {
  font-size: 22rpx;
  color: #7a6330;
  margin-bottom: 8rpx;
}
.hex-name {
  font-size: 36rpx;
  color: #e8d5a3;
  letter-spacing: 0.1em;
  text-align: center;
}

.arrow-between {
  font-size: 36rpx;
  color: #7a6330;
  align-self: center;
  padding-top: 80rpx;
}

.result-note {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #7a6330;
  margin: 20rpx 0 32rpx;
}

/* ── Interpretation ── */
.interp-toggle {
  display: block;
  width: 100%;
  background: transparent;
  border: 1rpx solid #2a2010;
  border-radius: 4rpx;
  color: #c9a84c;
  font-size: 28rpx;
  letter-spacing: 0.2em;
  padding: 28rpx 0;
  text-align: center;
}
.interp-toggle::after { border: none; }

.interp-section {
  margin-top: 24rpx;
}
.interp-card {
  background: #080806;
  border: 1rpx solid #2a2010;
  border-radius: 4rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
}
.interp-tag {
  display: block;
  font-size: 22rpx;
  color: #7a6330;
  letter-spacing: 0.2em;
  margin-bottom: 12rpx;
}
.interp-name {
  display: block;
  font-size: 32rpx;
  color: #c9a84c;
  margin-bottom: 20rpx;
}
.interp-body {
  display: block;
  font-size: 26rpx;
  color: #e8d5a3;
  line-height: 1.9;
}

/* ── Footer ── */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-size: 22rpx;
  color: #7a6330;
  letter-spacing: 0.2em;
}
