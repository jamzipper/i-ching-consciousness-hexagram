page {
  --gold: #c9a84c;
  --gold-light: #e8d5a3;
  --gold-dim: #7a6330;
  --gold-faint: #2a2010;
  --bg: #080806;
  --bg-card: #111108;
  --red: #c0392b;
  --red-glow: rgba(192, 57, 43, 0.7);

  background: var(--bg);
  color: var(--gold-light);
  font-family: 'PingFang SC', 'Noto Serif TC', 'SimSun', serif;
  min-height: 100vh;
}

.card {
  background: var(--bg-card);
  border: 1rpx solid #2e2510;
  border-radius: 6rpx;
  padding: 48rpx;
  width: 100%;
  margin: 16rpx 0;
}

.step-tag {
  font-size: 22rpx;
  letter-spacing: 0.3em;
  color: var(--gold-dim);
  margin-bottom: 18rpx;
  text-transform: uppercase;
}

.card-title {
  font-size: 28rpx;
  color: var(--gold);
  margin-bottom: 24rpx;
  letter-spacing: 0.05em;
  font-weight: bold;
}

.hint {
  font-size: 26rpx;
  color: var(--gold-dim);
  line-height: 1.7;
  margin-top: 16rpx;
}

.btn {
  display: inline-block;
  background: transparent;
  border: 1rpx solid var(--gold-dim);
  color: var(--gold-dim);
  font-size: 30rpx;
  padding: 18rpx 48rpx;
  letter-spacing: 0.1em;
  border-radius: 4rpx;
  margin-top: 28rpx;
}

.btn-primary {
  border-color: var(--gold);
  color: var(--gold);
}

.btn-primary:active {
  background: var(--gold);
  color: #080806;
}

.hr {
  width: 300rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  margin: 36rpx auto;
}

.hidden {
  display: none !important;
}
